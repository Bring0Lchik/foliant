<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8"><title><%= title %></title><style>body{font-family:Arial,sans-serif;font-size:10pt;color:#333}h1,h2,h3{font-family:'Times New Roman',serif;color:#000;margin-bottom:.5em;page-break-after:avoid}h1{font-size:24pt;border-bottom:2px solid #333;padding-bottom:10px;margin-bottom:20px;text-align:center}table{width:100%;border-collapse:collapse;margin-top:10px;page-break-inside:auto}tr{page-break-inside:avoid;page-break-after:auto}th,td{border:1px solid #ddd;padding:6px;text-align:left;vertical-align:top;font-size:9pt}th{background-color:#f2f2f2;font-weight:700}.no-data{text-align:center;padding:20px;font-style:italic;color:#777}</style>
</head>
<body>
    <h1><%= title %></h1>
    <p style="text-align:center;font-size:9pt">Период: с <%= filters.startDate || 'начала времен' %> по <%= filters.endDate || 'сегодня' %></p>

    <% if (customerActivityReport && customerActivityReport.length > 0) { %>
        <table>
            <thead><tr><th>ФИО</th><th>Email</th><th>Кол-во заказов</th><th>Сумма покупок</th><th>Средний чек</th><th>Последний заказ</th></tr></thead>
            <tbody>
                <% customerActivityReport.forEach(client => { %>
                    <tr><td><%= client.full_name %></td><td><%= client.email %></td><td><%= Number(client.order_count||0) %></td><td><%= Number(client.ltv||0).toFixed(2) %> ₽</td><td><%= Number(client.avg_check||0).toFixed(2) %> ₽</td><td><%= client.last_order_date ? new Date(client.last_order_date).toLocaleDateString('ru-RU') : 'Нет' %></td></tr>
                <% }) %>
            </tbody>
        </table>
    <% } else { %>
        <div class="no-data">Нет данных за выбранный период.</div>
    <% } %>

    <p style="text-align:right;font-size:8pt;color:#777;margin-top:30px">Дата формирования: <%= new Date().toLocaleString('ru-RU') %></p>
</body>
</html>