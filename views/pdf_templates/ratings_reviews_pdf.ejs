<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8"><title><%= title %></title><style>body{font-family:Arial,sans-serif;font-size:10pt;color:#333}h1,h2,h3{font-family:'Times New Roman',serif;color:#000;margin-bottom:.5em;page-break-after:avoid}h1{font-size:24pt;border-bottom:2px solid #333;padding-bottom:10px;margin-bottom:20px;text-align:center}h3{font-size:12pt;margin-top:15px;font-weight:700}table{width:100%;border-collapse:collapse;margin-top:10px;page-break-inside:auto}tr{page-break-inside:avoid;page-break-after:auto}td{border:1px solid #ddd;padding:6px;text-align:left;vertical-align:top;font-size:9pt}.low-rating-warning{background-color:#f8d7da!important;font-weight:700}.no-data{text-align:center;padding:20px;font-style:italic;color:#777}</style>
</head>
<body>
    <h1><%= title %></h1>
    <p style="text-align:center;font-size:9pt">Период: с <%= filters.startDate || 'начала времен' %> по <%= filters.endDate || 'сегодня' %></p>

    <% if (ratingsAndReviewsReport && ratingsAndReviewsReport.length > 0) { %>
        <% ratingsAndReviewsReport.forEach(book => { %>
            <h3 class="<%= Number(book.average_rating||0) < 3.0 ? 'low-rating-warning' : '' %>">Книга: <%= book.book_title %></h3>
            <p style="font-size:9pt">Средний рейтинг: <strong><%= Number(book.average_rating||0).toFixed(2) %> / 5</strong> | Оценок: <strong><%= Number(book.total_ratings||0) %></strong> | Отзывов: <strong><%= Number(book.total_reviews||0) %></strong></p>
            <% if (book.reviews.length > 0) { %>
                <table>
                    <% book.reviews.forEach(review => { %>
                        <tr><td><strong><%= review.user_name %> (<%= review.rating %>/5):</strong> <%- review.comment %></td></tr>
                    <% }) %>
                </table>
            <% } %>
        <% }) %>
    <% } else { %>
        <div class="no-data">Нет данных за выбранный период.</div>
    <% } %>

    <p style="text-align:right;font-size:8pt;color:#777;margin-top:30px">Дата формирования: <%= new Date().toLocaleString('ru-RU') %></p>
</body>
</html>