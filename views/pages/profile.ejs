<div class="container">
    <h1>Личный кабинет</h1>

    <div style="display: grid; grid-template-columns: 1fr 2fr; gap: 40px;">
        <div>
            <h3>Данные профиля</h3>
            <div class="form-container" style="margin: 0; padding: 20px;">
                <form action="/profile" method="POST">
                    <div class="form-group">
                        <label for="full_name">ФИО</label>
                        <input type="text" name="full_name" class="form-control" value="<%= profile.full_name %>">
                    </div>
                    <div class="form-group">
                        <label for="email">Email</label>
                        <input type="email" name="email" class="form-control" value="<%= profile.email %>" disabled>
                    </div>
                    <div class="form-group">
                        <label for="delivery_address">Адрес доставки</label>
                        <textarea id="delivery_address" name="delivery_address" rows="3"
                            class="form-control"><%= profile.delivery_address || '' %></textarea>
                        <div id="yandex-map"
                            style="width: 100%; height: 300px; margin-top: 15px; border-radius: var(--border-radius);">
                        </div>
                    </div>
                    <button type="submit" class="btn btn-primary">Сохранить</button>
                </form>
            </div>
        </div>
        <div>
            <h3>История заказов</h3>
            <% if (locals.orders && orders.length > 0) { %>
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>ID Заказа</th>
                        <th>Дата</th>
                        <th>Сумма</th>
                        <th>Статус</th>
                        <th>Действия</th>
                    </tr>
                </thead>
                <tbody>
                    <% orders.forEach(order => { %>
                    <tr>
                        <td>#<%= order.id %></td>
                        <td><%= new Date(order.created_at).toLocaleDateString('ru-RU') %></td>
                        <td><%= Number(order.total_amount).toFixed(2) %> ₽</td>
                        <td>
                            <span class="status-badge status-<%= order.status %>"><%= order.status %></span>
                        </td>
                        <td>
                            <a href="/order/<%= order.id %>" class="btn btn-sm btn-secondary">Подробнее</a>
                        </td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
            <% } else { %>
            <p>У вас еще нет заказов.</p>
            <% } %>
        </div>
    </div>
</div>

<% contentFor('scripts') %>
<script src="https://api-maps.yandex.ru/2.1/?apikey=<%= yandexApiKey %>&lang=ru_RU" type="text/javascript"></script>
<script type="text/javascript">
    if (typeof ymaps !== 'undefined') {
        ymaps.ready(init);
    }

    function init() {
        const addressField = document.getElementById('delivery_address');
        const mapContainer = document.getElementById('yandex-map');
        if (!mapContainer || !addressField) return;

        const initialAddress = addressField.value || 'Москва, Кремль';
        const myMap = new ymaps.Map('yandex-map', {
            center: [55.75, 37.61],
            zoom: 10,
            controls: ['zoomControl', 'searchControl']
        });
        let myPlacemark;

        function updatePlacemarkAndAddress(coords, addressText) {
            addressField.value = addressText;
            if (myPlacemark) myMap.geoObjects.remove(myPlacemark);
            myPlacemark = new ymaps.Placemark(coords, {}, {
                preset: 'islands#violetDotIconWithCaption',
                draggable: true
            });
            myMap.geoObjects.add(myPlacemark);
            myPlacemark.events.add('dragend', () => getAddress(myPlacemark.geometry.getCoordinates()));
        }

        function getAddress(coords) {
            ymaps.geocode(coords).then(res => {
                const firstGeoObject = res.geoObjects.get(0);
                if (firstGeoObject) {
                    const addressText = firstGeoObject.getAddressLine();
                    updatePlacemarkAndAddress(coords, addressText);
                }
            });
        }

        myMap.events.add('click', e => getAddress(e.get('coords')));
        myMap.controls.get('searchControl').events.add('resultselect', e => {
            const index = e.get('index');
            myMap.controls.get('searchControl').getResult(index).then(res => {
                updatePlacemarkAndAddress(res.geometry.getCoordinates(), res.getAddressLine());
            });
        });

        if (initialAddress) {
            ymaps.geocode(initialAddress).then(res => {
                const firstGeoObject = res.geoObjects.get(0);
                if (firstGeoObject) {
                    const coords = firstGeoObject.geometry.getCoordinates();
                    myMap.setCenter(coords);
                    updatePlacemarkAndAddress(coords, firstGeoObject.getAddressLine());
                }
            });
        }
    }
</script>
