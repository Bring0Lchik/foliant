<h1>Управление пользователями</h1>

<table class="admin-table">
    <thead>
        <tr>
            <th>ID</th>
            <th>ФИО</th>
            <th>Email</th>
            <th>Роль</th>
            <th>Статус</th>
            <th>Действия</th>
        </tr>
    </thead>
    <tbody>
        <% users.forEach(user => { %>
            <tr>
                <td><%= user.id %></td>
                <td><%= user.full_name %></td>
                <td><%= user.email %></td>
                <td>
                    <%= user.role_name %>
                    <% if (user.id === superAdminId) { %>
                        <i class="fa-solid fa-crown" style="color: gold;" title="Супер-администратор"></i>
                    <% } %>
                </td>
                <td>
                    <span class="status-badge <%= user.is_blocked ? 'status-blocked' : 'status-active' %>">
                        <%= user.is_blocked ? 'Заблокирован' : 'Активен' %>
                    </span>
                </td>
                <td class="table-actions">
                    <a href="/admin/user/<%= user.id %>" class="btn btn-secondary btn-sm">Подробнее</a>
                </td>
            </tr>
        <% }) %>
    </tbody>
</table>