<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
    <h1>Управление книгами</h1>
    <a href="/admin/books/add" class="btn btn-primary"><i class="fa-solid fa-plus"></i> Добавить книгу</a>
</div>

<table class="admin-table">
    <thead>
        <tr>
            <th>ID</th>
            <th>Название</th>
            <th>Цена</th>
            <th>Остаток</th>
            <th>Действия</th>
        </tr>
    </thead>
    <tbody>
        <% books.forEach(book => { %>
            <tr>
                <td><%= book.id %></td>
                <td><%= book.title %></td>
                <td><%= book.price %> ₽</td>
                <td><%= book.stock_quantity %> шт.</td>
                <td class="table-actions">
                    <a href="/admin/books/edit/<%= book.id %>" class="btn btn-secondary"><i class="fa-solid fa-pencil"></i></a>
                    <form action="/admin/books/delete/<%= book.id %>" method="POST" onsubmit="return confirm('Вы уверены, что хотите удалить эту книгу?');">
                        <button type="submit" class="btn btn-danger"><i class="fa-solid fa-trash-can"></i></button>
                    </form>
                </td>
            </tr>
        <% }) %>
    </tbody>
</table>

<% if (totalPages > 1) { %>
    <nav>
        <ul class="pagination">
            <% if (currentPage > 1) { %>
                <li><a href="/admin/books?page=<%= currentPage - 1 %>">«</a></li>
            <% } else { %>
                <li class="disabled"><span>«</span></li>
            <% } %>

            <% for (let i = 1; i <= totalPages; i++) { %>
                <li><a href="/admin/books?page=<%= i %>" class="<%= i === currentPage ? 'active' : '' %>"><%= i %></a></li>
            <% } %>

            <% if (currentPage < totalPages) { %>
                <li><a href="/admin/books?page=<%= currentPage + 1 %>">»</a></li>
            <% } else { %>
                 <li class="disabled"><span>»</span></li>
            <% } %>
        </ul>
    </nav>
<% } %>