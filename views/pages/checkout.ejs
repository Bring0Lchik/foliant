<div class="container">
    <h1>Оформление заказа</h1>
    <form action="/order" method="POST">
        <div style="display: grid; grid-template-columns: 2fr 1fr; gap: 40px;">
            <!-- Левая колонка: Адрес -->
            <div>
                <h3>1. Адрес доставки</h3>
                <div class="form-group">
                    <label for="delivery_address">Укажите или уточните ваш адрес</label>
                    <textarea id="delivery_address" name="delivery_address" rows="3" class="form-control"
                        required><%= user.delivery_address || '' %></textarea>
                    <div id="yandex-map"
                        style="width: 100%; height: 300px; margin-top: 15px; border-radius: var(--border-radius);"></div>
                </div>
            </div>
            <!-- Правая колонка: Состав заказа -->
            <div>
                <h3>2. Ваш заказ</h3>
                <ul class="book-specs">
                    <% items.forEach(item => { %>
                    <li>
                        <span><%= item.title %> (x<%= item.quantity %>)</span>
                        <strong><%= (Number(item.effective_price) * item.quantity).toFixed(2) %> ₽</strong>
                    </li>
                    <!-- Скрытые поля для отправки ID купленных товаров -->
                    <input type="hidden" name="selected_items" value="<%= item.book_id %>">
                    <% }) %>
                    <li style="border-top: 2px solid var(--color-gray-dark); margin-top: 10px; padding-top: 10px;">
                        <span>Итого</span>
                        <strong><%= Number(total).toFixed(2) %> ₽</strong>
                    </li>
                </ul>
                <!-- Финальная кнопка -->
                <button type="submit" class="btn btn-primary" style="width: 100%;">Подтвердить заказ</button>
            </div>
        </div>
    </form>
</div>

<% contentFor('scripts', `
<script src="https://api-maps.yandex.ru/2.1/?apikey=${yandexApiKey}&lang=ru_RU" type="text/javascript"></script>
<script type="text/javascript">
    if (typeof ymaps !== 'undefined') {
        ymaps.ready(init);
    }
    function init() {
        const addressField = document.getElementById('delivery_address');
        const mapContainer = document.getElementById('yandex-map');
        if (!mapContainer || !addressField) return;

        const initialAddress = addressField.value || 'Москва, Кремль';
        const myMap = new ymaps.Map('yandex-map', {
            center: [55.75, 37.61], zoom: 10, controls: ['zoomControl', 'searchControl']
        });
        let myPlacemark;

        function updatePlacemarkAndAddress(coords, addressText) {
            addressField.value = addressText;
            if (myPlacemark) myMap.geoObjects.remove(myPlacemark);
            myPlacemark = new ymaps.Placemark(coords, {}, { preset: 'islands#violetDotIconWithCaption', draggable: true });
            myMap.geoObjects.add(myPlacemark);
            myPlacemark.events.add('dragend', () => getAddress(myPlacemark.geometry.getCoordinates()));
        }

        function getAddress(coords) {
            ymaps.geocode(coords).then(res => {
                const firstGeoObject = res.geoObjects.get(0);
                if(firstGeoObject) {
                    const addressText = firstGeoObject.getAddressLine();
                    updatePlacemarkAndAddress(coords, addressText);
                }
            });
        }
        
        myMap.events.add('click', e => getAddress(e.get('coords')));
        myMap.controls.get('searchControl').events.add('resultselect', e => {
            const index = e.get('index');
            myMap.controls.get('searchControl').getResult(index).then(res => {
                updatePlacemarkAndAddress(res.geometry.getCoordinates(), res.getAddressLine());
            });
        });

        if (initialAddress) {
            ymaps.geocode(initialAddress).then(res => {
                const firstGeoObject = res.geoObjects.get(0);
                if (firstGeoObject) {
                    const coords = firstGeoObject.geometry.getCoordinates();
                    myMap.setCenter(coords);
                    updatePlacemarkAndAddress(coords, firstGeoObject.getAddressLine());
                }
            });
        }
    }
</script>
`) %>